# App URL for Stripe redirect URLs (set on Vercel Production to your prod domain, no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — TEST keys only during beta (https://dashboard.stripe.com/test/apikeys)
# Do not use sk_live_ / pk_live_ until legal entity exists.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: use pre-created Price IDs instead of inline price_data (test mode prices)
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_MONTHLY=price_...

# After company registration only: set to 1 and switch to live keys + live webhook
# STRIPE_ALLOW_LIVE=1
